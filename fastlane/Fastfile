default_platform(:ios)

platform :ios do
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )

    # Update Xcode project signing settings to use match profiles
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: "VC5H5G22FQ",
      bundle_identifier: "com.private-4t.app",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore com.private-4t.app"
    )

    # Build Flutter app from project root (sh runs from fastlane/ dir by default)
    sh("cd .. && flutter build ios --release --no-codesign")

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      codesigning_identity: "iPhone Distribution",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.private-4t.app" => "match AppStore com.private-4t.app"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end