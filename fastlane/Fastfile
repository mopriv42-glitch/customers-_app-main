default_platform(:ios)

platform :ios do
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )

    # Update Xcode project signing settings to use match profiles
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: "VC5H5G22FQ",
      bundle_identifier: "com.private-4t.app",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore com.private-4t.app"
    )

    # Use flutter build ipa directly — this is the Flutter-recommended CI method.
    # Unlike build_app (which hangs because xcode_backend.sh can't find Flutter env),
    # flutter build ipa handles the entire Xcode build internally with proper env setup.
    sh("cd .. && flutter build ipa --release --export-options-plist=ios/ExportOptions.plist")

    # Find and upload the built IPA
    ipa_path = Dir.glob("../build/ios/ipa/*.ipa").first
    UI.user_error!("No IPA found in build/ios/ipa/") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end